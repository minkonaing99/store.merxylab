# Copy to .env.local and fill in real values. Never commit .env.local.

# Phase 5+
# Either set DATABASE_URL directly...
DATABASE_URL="mysql://USER:PASS@localhost:3306/merxylab-store"
# ...or set the components separately (used on Hostinger Easy Deploy):
# DB_HOST="127.0.0.1"
# DB_PORT="3306"
# DB_USER="u123456_merxylab"
# DB_PASS="strongpassword"
# DB_NAME="u123456_merxylab_store"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

