# Copy to .env.local and fill in real values. Never commit .env.local.

# Phase 5+
# Either set DATABASE_URL directly...
DATABASE_URL="mysql://USER:PASS@localhost:3306/merxylab-store"
# ...or set the components separately (used on Hostinger Easy Deploy):
# DB_HOST="127.0.0.1"
# DB_PORT="3306"
# DB_USER="u123456_merxylab"
# DB_PASS="strongpassword"
# DB_NAME="u123456_merxylab_store"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Phase 6+ (Auth.js, SMTP)
# AUTH_SECRET="generate with: openssl rand -base64 32"
# AUTH_URL="http://localhost:3000"
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# SMTP_HOST="smtp.hostinger.com"
# SMTP_PORT="465"
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM="merxylab <noreply@your-domain.com>"
# BANK_PAYMENT_INSTRUCTIONS=""

# Phase 7 (optional)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Phase 9 (checkout + Telegram owner alerts)
# TELEGRAM_BACKUP_USERNAME="merxylab"          # public link shown to customers as backup contact
# TELEGRAM_BOT_TOKEN=""                        # owner alert bot
# TELEGRAM_OWNER_CHAT_ID=""                    # owner Telegram chat ID to receive alerts

# Phase 11 (Cloudflare R2 — product photos, payment-method QR, slips)
# R2_ACCOUNT_ID=""                             # CF account id (R2 dashboard -> Use S3 API)
# R2_ACCESS_KEY_ID=""                          # R2 API token, write+delete on both buckets
# R2_SECRET_ACCESS_KEY=""
# R2_PUBLIC_BUCKET="merxylab-public"           # holds products/* + payment-qr/*
# R2_PRIVATE_BUCKET="merxylab-private"         # holds slips/<orderId>/<uuid>.webp
# NEXT_PUBLIC_CDN_URL="https://cdn.merxylab.com"  # custom domain bound to public bucket
