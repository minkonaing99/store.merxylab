{
  "name": "merxylab-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "photos:check": "tsx scripts/check-photos.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:seed:payment": "tsx --env-file=.env.local scripts/seed-payment.ts",
    "cron:cancel-expired": "tsx --env-file=.env.local scripts/cancel-expired-orders.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@tailwindcss/postcss": "^4.3.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.18.0",
    "mysql2": "^3.22.5",
    "next": "^15.5.19",
    "next-auth": "5.0.0-beta.25",
    "nodemailer": "^9.0.0",
    "postcss": "^8.5.15",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.0",
    "tsx": "^4.22.4",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "sharp@0.35.1": true,
    "unrs-resolver@1.12.2": true,
    "sharp@0.34.5": true
  }
}
